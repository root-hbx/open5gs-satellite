#!/bin/bash
# filepath: /home/parallels/open5gs-satellite/activate-opensat

PROJECT_ROOT="$(realpath $(dirname "${BASH_SOURCE[0]}"))"
VENV_DIR="${PROJECT_ROOT}/.venv"
OPENSAT_SCRIPT="${PROJECT_ROOT}/cli/opensat.py"

# check if pyvenv is installed; if not, install it
if [ ! -d "${VENV_DIR}" ]; then
    echo "Virtual environment not found. Creating a new one..."
    python3 -m venv "${VENV_DIR}"
    
    # check if the virtual environment was created successfully
    if [ $? -ne 0 ]; then
        echo "Error: Failed to create virtual environment. Please make sure python3-venv is installed."
        echo "On Ubuntu/Debian: sudo apt install python3-venv"
        exit 1
    fi
    
    echo "Virtual environment created successfully at ${VENV_DIR}"
    
    # if requirements.txt exists, install all dependencies provided
    if [ -f "${PROJECT_ROOT}/requirements.txt" ]; then
        echo "Installing dependencies from requirements.txt..."
        "${VENV_DIR}/bin/pip" install -r "${PROJECT_ROOT}/requirements.txt"
    fi
fi

source "${VENV_DIR}/bin/activate"

# check if the opensat.py script exists
if [ ! -f "${OPENSAT_SCRIPT}" ]; then
    echo "Error: '${OPENSAT_SCRIPT}' not found."
    echo "Please make sure the script exists in the cli directory."
    exit 1
fi

# chmod check
if [ ! -x "${OPENSAT_SCRIPT}" ]; then
    echo "Making '${OPENSAT_SCRIPT}' executable..."
    chmod +x "${OPENSAT_SCRIPT}"
fi

# alias for cli/opensat.py
alias opensat="${OPENSAT_SCRIPT}"

echo "OpenSat environment activated. You can now use the 'opensat' command."
echo "Run 'opensat help' to see available commands."
